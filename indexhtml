<div>import React, { useState, useMemo } from 'react';<br>
import { <br>
&nbsp; Heart, Droplets, Sparkles, Calendar as CalendarIcon, <br>
&nbsp; Settings, ChevronLeft, ChevronRight, Plus, X, <br>
&nbsp; Smile, Frown, Angry, CloudRain, Coffee<br>
} from 'lucide-react';<br>
<br>
// --- UTILITY FUNCTIONS ---<br>
const normalizeDate = (d) =&gt; {<br>
&nbsp; const date = new Date(d);<br>
&nbsp; date.setHours(0, 0, 0, 0);<br>
&nbsp; return date;<br>
};<br>
<br>
const formatDateStr = (date) =&gt; {<br>
&nbsp; const d = new Date(date);<br>
&nbsp; const year = d.getFullYear();<br>
&nbsp; const month = String(d.getMonth() + 1).padStart(2, '0');<br>
&nbsp; const day = String(d.getDate()).padStart(2, '0');<br>
&nbsp; return `${year}-${month}-${day}`;<br>
};<br>
<br>
const addDays = (date, days) =&gt; {<br>
&nbsp; const result = new Date(date);<br>
&nbsp; result.setDate(result.getDate() + days);<br>
&nbsp; return result;<br>
};<br>
<br>
const getDaysDifference = (date1, date2) =&gt; {<br>
&nbsp; const diffTime = Math.abs(normalizeDate(date2) - normalizeDate(date1));<br>
&nbsp; return Math.ceil(diffTime / (1000 * 60 * 60 * 24));<br>
};<br>
<br>
export default function App() {<br>
&nbsp; // --- STATE MANAGEMENT ---<br>
&nbsp; const [isSetupComplete, setIsSetupComplete] = useState(false);<br>
&nbsp; const [cycleLength, setCycleLength] = useState(28);<br>
&nbsp; const [periodLength, setPeriodLength] = useState(5);<br>
&nbsp; const [lastPeriodDate, setLastPeriodDate] = useState(formatDateStr(new Date()));<br>
&nbsp; <br>
&nbsp; const [currentMonthDate, setCurrentMonthDate] = useState(normalizeDate(new Date()));<br>
&nbsp; const [selectedDate, setSelectedDate] = useState(null);<br>
&nbsp; const [showLogModal, setShowLogModal] = useState(false);<br>
&nbsp; const [showSettingsModal, setShowSettingsModal] = useState(false);<br>
&nbsp; <br>
&nbsp; // Logs memory structure: { 'YYYY-MM-DD': { mood: 'Happy', symptoms: ['Cramps'] } }<br>
&nbsp; const [logs, setLogs] = useState({});<br>
<br>
&nbsp; // --- CALCULATIONS ---<br>
&nbsp; const today = normalizeDate(new Date());<br>
&nbsp; <br>
&nbsp; // Predict upcoming dates based on last period<br>
&nbsp; const predictions = useMemo(() =&gt; {<br>
&nbsp;&nbsp;&nbsp; const lastP = normalizeDate(lastPeriodDate);<br>
&nbsp;&nbsp;&nbsp; const nextP = addDays(lastP, cycleLength);<br>
&nbsp;&nbsp;&nbsp; const nextOvulation = addDays(nextP, -14);<br>
&nbsp;&nbsp;&nbsp; const fertileStart = addDays(nextOvulation, -3);<br>
&nbsp;&nbsp;&nbsp; const fertileEnd = addDays(nextOvulation, 1);<br>
&nbsp;&nbsp;&nbsp; <br>
&nbsp;&nbsp;&nbsp; // Days until next period<br>
&nbsp;&nbsp;&nbsp; let daysUntilNext = getDaysDifference(today, nextP);<br>
&nbsp;&nbsp;&nbsp; if (today &gt; nextP) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; // If today is past the predicted next period, predict the one after<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; daysUntilNext = cycleLength - (getDaysDifference(nextP, today) % cycleLength);<br>
&nbsp;&nbsp;&nbsp; }<br>
<br>
&nbsp;&nbsp;&nbsp; // Determine current phase<br>
&nbsp;&nbsp;&nbsp; let currentPhase = "Folikuler";<br>
&nbsp;&nbsp;&nbsp; let phaseDesc = "Waktu yang tepat untuk mencoba hal baru!";<br>
&nbsp;&nbsp;&nbsp; const daysSinceLastP = getDaysDifference(lastP, today);<br>
&nbsp;&nbsp;&nbsp; <br>
&nbsp;&nbsp;&nbsp; if (today &gt;= lastP &amp;&amp; today &lt; addDays(lastP, periodLength)) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; currentPhase = "Menstruasi";<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; phaseDesc = "Waktunya istirahat dan manjakan dirimu &#127800;";<br>
&nbsp;&nbsp;&nbsp; } else if (today &gt;= fertileStart &amp;&amp; today &lt;= fertileEnd) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; currentPhase = "Masa Subur";<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; phaseDesc = "Energi sedang tinggi-tingginya! &#10024;";<br>
&nbsp;&nbsp;&nbsp; } else if (today &gt; fertileEnd &amp;&amp; today &lt; nextP) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; currentPhase = "Luteal";<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; phaseDesc = "Mungkin terasa sedikit lelah, tetap terhidrasi ya &#128167;";<br>
&nbsp;&nbsp;&nbsp; }<br>
<br>
&nbsp;&nbsp;&nbsp; return { nextPeriod: nextP, fertileStart, fertileEnd, daysUntilNext, currentPhase, phaseDesc };<br>
&nbsp; }, [lastPeriodDate, cycleLength, periodLength, today]);<br>
<br>
&nbsp; // --- HANDLERS ---<br>
&nbsp; const handleSetupSubmit = (e) =&gt; {<br>
&nbsp;&nbsp;&nbsp; e.preventDefault();<br>
&nbsp;&nbsp;&nbsp; setIsSetupComplete(true);<br>
&nbsp; };<br>
<br>
&nbsp; const handleSaveLog = (dateStr, logData) =&gt; {<br>
&nbsp;&nbsp;&nbsp; setLogs(prev =&gt; ({<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ...prev,<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; [dateStr]: logData<br>
&nbsp;&nbsp;&nbsp; }));<br>
&nbsp;&nbsp;&nbsp; setShowLogModal(false);<br>
&nbsp; };<br>
<br>
&nbsp; const prevMonth = () =&gt; {<br>
&nbsp;&nbsp;&nbsp; setCurrentMonthDate(addDays(currentMonthDate, -30)); // Approximate, fine for UI shift<br>
&nbsp; };<br>
<br>
&nbsp; const nextMonth = () =&gt; {<br>
&nbsp;&nbsp;&nbsp; setCurrentMonthDate(addDays(currentMonthDate, 30));<br>
&nbsp; };<br>
<br>
&nbsp; // --- CALENDAR GENERATION ---<br>
&nbsp; const renderCalendarDays = () =&gt; {<br>
&nbsp;&nbsp;&nbsp; const year = currentMonthDate.getFullYear();<br>
&nbsp;&nbsp;&nbsp; const month = currentMonthDate.getMonth();<br>
&nbsp;&nbsp;&nbsp; <br>
&nbsp;&nbsp;&nbsp; const firstDay = new Date(year, month, 1);<br>
&nbsp;&nbsp;&nbsp; const lastDay = new Date(year, month + 1, 0);<br>
&nbsp;&nbsp;&nbsp; const daysInMonth = lastDay.getDate();<br>
&nbsp;&nbsp;&nbsp; const startingDayOfWeek = firstDay.getDay(); // 0: Sun, 1: Mon...<br>
&nbsp;&nbsp;&nbsp; <br>
&nbsp;&nbsp;&nbsp; const days = [];<br>
&nbsp;&nbsp;&nbsp; <br>
&nbsp;&nbsp;&nbsp; // Empty cells for alignment<br>
&nbsp;&nbsp;&nbsp; for (let i = 0; i &lt; startingDayOfWeek; i++) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; days.push(&lt;div key={`empty-${i}`} className="h-10 w-10"&gt;&lt;/div&gt;);<br>
&nbsp;&nbsp;&nbsp; }<br>
&nbsp;&nbsp;&nbsp; <br>
&nbsp;&nbsp;&nbsp; // Day cells<br>
&nbsp;&nbsp;&nbsp; const lastP = normalizeDate(lastPeriodDate);<br>
<br>
&nbsp;&nbsp;&nbsp; for (let i = 1; i &lt;= daysInMonth; i++) {<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; const cellDate = new Date(year, month, i);<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; const cellDateStr = formatDateStr(cellDate);<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; const isToday = formatDateStr(cellDate) === formatDateStr(today);<br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; const hasLog = logs[cellDateStr] !== undefined;<br>
